{
  "version": 3,
  "framework": {
    "name": "nitro",
    "version": "3.0.1-20260512-093145-0498ce70"
  },
  "overrides": {},
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/assets/(.*)"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/__server"
    }
  ]
}